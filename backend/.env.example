# ---------------------------------------------------------------------------
# Conference Email System — backend environment configuration
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ---------------------------------------------------------------------------

# --- Swappable architecture flags ------------------------------------------
# Drafter provider — how replies are generated. Choose one:
#   anthropic_api : default. Hosted cloud API, highest quality. Requires
#                   ANTHROPIC_API_KEY. ("anthropic" is an accepted alias.)
#   local         : self-hosted, OpenAI-compatible inference server (no external
#                   API dependency). Requires a GPU / running inference server.
#   template      : zero dependency, no model call — fills a response template
#                   from retrieved policy text verbatim. Always available and
#                   grounded (no hallucination), but the most rigid output.
#                   Safest fallback when AI generation is restricted or the
#                   other backends are down.
#   fallback      : deterministic no-network stub (returns a placeholder draft).
MODEL_PROVIDER=local
# Local model (used only when MODEL_PROVIDER=local) — OpenAI-compatible endpoint,
# e.g. Ollama. The drafter POSTs to {LOCAL_MODEL_BASE_URL}/chat/completions.
LOCAL_MODEL_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL_NAME=llama3.1:8b
# Optional bearer token for the endpoint above. Leave unset for local
# unauthenticated servers; set it when LOCAL_MODEL_BASE_URL points at a hosted
# keyed service speaking the same chat-completions protocol.
# LOCAL_MODEL_API_KEY=

# Reply style/instruction guide (markdown) appended to the drafter's system
# prompt. Style/behavior only — always subordinate to the grounding rules.
# Path is relative to backend/ (the app's working dir); unset = no guide.
STYLE_GUIDE_PATH=../data/style_guide/style_guide_v2.md

# Minimum confidence required for Lane 1 (FAQ auto-reply). 0.0 - 1.0
CONFIDENCE_THRESHOLD=0.75

# Retrieval backend: "bm25" | "faiss" | "fusion". Default is fusion — E003
# validated the distill+fusion recipe (hit@3 .649 → .892 on real tickets).
RETRIEVAL_BACKEND=fusion

# Retrieval-query strategy: "prefix" (legacy body+intent, no model call) |
# "distill" (one LLM call → 1-3 compact policy-vocabulary queries + intent).
# Default is distill; pairs with RETRIEVAL_BACKEND=fusion. Falls back to
# keyword classifier + prefix query on any distiller error.
QUERY_STRATEGY=distill

# Routing strategy: "rule_based" | "rl"
ROUTING_STRATEGY=rule_based

# --- Pipeline tuning -------------------------------------------------------
# Minimum classifier confidence to qualify for the FAQ auto-reply lane. 0.0 - 1.0
FAQ_CONFIDENCE_THRESHOLD=0.65

# Max policy chunks the retriever returns as grounding context.
MAX_RETRIEVED_CHUNKS=3

# Max tokens the drafter may generate for a reply.
DRAFTER_MAX_TOKENS=500

# --- Transport / auto-send gate --------------------------------------------
# Master gate for any OUTBOUND reply to a requester (e.g. a public Zendesk
# reply). When False (the default), the send path only releases a draft a chair
# has explicitly approved, and public/auto replies to requesters are blocked
# entirely — drafts stay queued for human review. Flipping this True is what
# lets complete FAQ drafts release without per-email approval.
# MUST stay False until auto-send is explicitly signed off for production.
ALLOW_AUTO_SEND=False

# --- Secrets / connections -------------------------------------------------
# Anthropic API key (leave blank to use local fallback)
ANTHROPIC_API_KEY=

# --- Zendesk integration (credential layer) --------------------------------
# Auth mode selects the credential provider: "token" (API-token / HTTP Basic)
# or "oauth" (client_credentials). Callers use the same interface either way.
# RECOMMENDED: "oauth" — it is the validated/working path in production (see
# docs/ZENDESK_API.md). (The config.py code default is "token"; this example
# recommends oauth as the documented default for real deployments.)
ZENDESK_AUTH_MODE=oauth
# Account subdomain, e.g. "aaai" → https://aaai.zendesk.com. Required by BOTH
# auth modes (forms the REST base URL and the OAuth token endpoint host).
ZENDESK_SUBDOMAIN=
#
# --- Token (Basic) auth — required only when ZENDESK_AUTH_MODE=token
# Basic auth uses username "{email}/token" with the API token as the password.
ZENDESK_EMAIL=
ZENDESK_API_TOKEN=
#
# --- OAuth (client_credentials) — required only when ZENDESK_AUTH_MODE=oauth
# The registered OAuth client identifier.
ZENDESK_OAUTH_CLIENT_ID=
# The OAuth client secret. Read from here (Settings/.env) — never from a
# checked-in secrets file.
ZENDESK_OAUTH_CLIENT_SECRET=
# OAuth scope; read-only is sufficient for fetching tickets.
ZENDESK_OAUTH_SCOPE=read
#
# --- Zendesk polling (background read/ingest loop) -------------------------
# Gates the background loop that polls Zendesk for new/updated tickets and
# ingests them into the pipeline. When False (the default), the app never polls
# automatically — ingest happens only via the manual POST /api/v1/zendesk/sync
# trigger. Set True only to enable continuous background polling.
# MUST stay False until the Zendesk read/write integration is fully verified
# in production.
ZENDESK_POLLING_ENABLED=False
#
# Comma-separated allow-list of ticket statuses to INGEST. The incremental
# export has no server-side status filter, so this is applied client-side (skip
# tickets whose status isn't listed). Default below = every ingestable status,
# so leaving it unset changes nothing. Valid: new, open, pending, hold, solved,
# closed ("deleted" is always skipped and is not a valid value here).
# NOTE: "solved" and "closed" are the SAME bucket — a solved ticket
# auto-transitions to closed over time with no further chair action — so list
# both together (or neither) to keep that bucket whole.
ZENDESK_SYNC_STATUSES=new,open,pending,hold,solved,closed

# --- Database --------------------------------------------------------------
# Single async connection string, used by BOTH the FastAPI app's async engine
# and Alembic (migrations/env.py injects it) — there is no separate sync URL.
# asyncpg driver for PostgreSQL, aiosqlite for SQLite (normalized in
# app/db/database.py).
#
# NOTE: under `docker compose`, the backend service sets DATABASE_URL from the
# POSTGRES_* values (see docker-compose.yml) and that OVERRIDES anything here —
# so you do NOT set it in this file when running via compose. The values below
# are for running the backend directly on the host.
#
# PostgreSQL (production / host run against the compose db on 127.0.0.1:5432):
DATABASE_URL=postgresql+asyncpg://confmail:confmail@localhost:5432/confmail
#
# SQLite (local dev / tests) — uncomment to use instead:
# DATABASE_URL=sqlite+aiosqlite:///./conference_email.db
