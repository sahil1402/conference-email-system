# ---------------------------------------------------------------------------
# Conference Email System — backend environment configuration
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ---------------------------------------------------------------------------

# --- Swappable architecture flags ------------------------------------------
# Drafter provider — how replies are generated. Choose one:
#   anthropic_api : default. Hosted cloud API, highest quality. Requires
#                   ANTHROPIC_API_KEY. ("anthropic" is an accepted alias.)
#   local         : self-hosted, OpenAI-compatible inference server (no external
#                   API dependency). Requires a GPU / running inference server.
#   template      : zero dependency, no model call — fills a response template
#                   from retrieved policy text verbatim. Always available and
#                   grounded (no hallucination), but the most rigid output.
#                   Safest fallback when AI generation is restricted or the
#                   other backends are down.
#   fallback      : deterministic no-network stub (returns a placeholder draft).
MODEL_PROVIDER=anthropic
# Local model (used only when MODEL_PROVIDER=local) — OpenAI-compatible endpoint,
# e.g. Ollama. The drafter POSTs to {LOCAL_MODEL_BASE_URL}/chat/completions.
LOCAL_MODEL_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL_NAME=llama3.1:8b

# Minimum confidence required for Lane 1 (FAQ auto-reply). 0.0 - 1.0
CONFIDENCE_THRESHOLD=0.75

# Retrieval backend: "bm25" | "vector"
RETRIEVAL_BACKEND=bm25

# Routing strategy: "rule_based" | "rl"
ROUTING_STRATEGY=rule_based

# --- Pipeline tuning -------------------------------------------------------
# Minimum classifier confidence to qualify for the FAQ auto-reply lane. 0.0 - 1.0
FAQ_CONFIDENCE_THRESHOLD=0.65

# Max policy chunks the retriever returns as grounding context.
MAX_RETRIEVED_CHUNKS=3

# Max tokens the drafter may generate for a reply.
DRAFTER_MAX_TOKENS=500

# --- Secrets / connections -------------------------------------------------
# Anthropic API key (leave blank to use local fallback)
ANTHROPIC_API_KEY=

# --- Database --------------------------------------------------------------
# Primary async connection string (used by the app's async engine).
# DATABASE_URL drives the FastAPI app; SYNC_DATABASE_URL is for sync tooling.
#
# PostgreSQL (production):
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/confmail
SYNC_DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/confmail
#
# SQLite (local dev / tests) — uncomment to use instead:
# DATABASE_URL=sqlite+aiosqlite:///./conference_email.db
# SYNC_DATABASE_URL=sqlite:///./conference_email.db
