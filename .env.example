# ===========================================================================
# Conference Email System — root environment reference
# ---------------------------------------------------------------------------
# Documents every env var across the monorepo. Each app reads its own scoped
# file at runtime:
#   - Backend  → backend/.env        (see backend/.env.example)
#   - Frontend → frontend/.env.local
# Copy the relevant section into the appropriate file. Never commit real secrets.
# ===========================================================================

# ---------------------------------------------------------------------------
# BACKEND (FastAPI) — place these in backend/.env
# ---------------------------------------------------------------------------

# Swappable architecture flags
MODEL_PROVIDER=anthropic_api          # "anthropic_api" | "local"
CONFIDENCE_THRESHOLD=0.75             # 0.0 - 1.0; min confidence for auto-reply
RETRIEVAL_BACKEND=bm25                # "bm25" | "vector"
ROUTING_STRATEGY=rule_based           # "rule_based" | "rl"

# Secrets / connections
ANTHROPIC_API_KEY=                    # leave blank to use local fallback
DATABASE_URL=sqlite:///./conference_email.db

# ---------------------------------------------------------------------------
# FRONTEND (Next.js) — place these in frontend/.env.local
# ---------------------------------------------------------------------------

# Base URL of the backend API (exposed to the browser, hence NEXT_PUBLIC_)
NEXT_PUBLIC_API_URL=http://localhost:8000
