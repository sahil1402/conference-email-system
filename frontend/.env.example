# ---------------------------------------------------------------------------
# Conference Email System — frontend environment configuration
# Copy this file to `.env.local` and adjust for your environment.
# Never commit `.env.local`.
# ---------------------------------------------------------------------------

# Base URL of the backend API. Exposed to the browser (hence NEXT_PUBLIC_),
# so it must be a URL the browser can reach. Include the /api/v1 prefix.
#   - Local dev:   http://localhost:8000/api/v1
#   - Production:  https://<your-backend-host>/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
